{
  "expo": {
    "name": "Live Earth Dashboard",
    "slug": "live-earth-dashboard",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "processing",
          "remote-notification"
        ]
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-background-task",
      "expo-notifications"
    ]
  }
}
